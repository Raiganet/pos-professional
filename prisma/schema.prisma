generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         String        @default("KASIR")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Brand {
  id        String   @id @default(cuid())
  nama      String   @unique
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  produks   Produk[]
}

model Kategori {
  id        String   @id @default(cuid())
  nama      String   @unique
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  produks   Produk[]
}

model Supplier {
  id        String   @id @default(cuid())
  nama      String
  telepon   String?
  email     String?
  alamat    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  produks   Produk[]
}

model Pelanggan {
  id           String        @id @default(cuid())
  nama         String
  telepon      String?
  email        String?
  alamat       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Produk {
  id            String            @id @default(cuid())
  barcode       String            @unique
  nama          String
  harga         Int
  hargaModal    Int               @default(0)
  stok          Int               @default(0)
  minimalStok   Int               @default(10)
  gambar        String?
  deskripsi     String?
  statusAktif   Boolean           @default(true)
  brandId       String?
  kategoriId    String?
  supplierId    String?
  brand         Brand?            @relation(fields: [brandId], references: [id])
  kategori      Kategori?         @relation(fields: [kategoriId], references: [id])
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  details       DetailTransaksi[]
  stokMovements StokMovement[]
}

model Transaction {
  id           String            @id @default(cuid())
  nomor        String            @unique
  subtotal     Int
  diskon       Int               @default(0)
  pajak        Int
  grandTotal   Int
  bayar        Int
  kembalian    Int
  metodeBayar  String
  catatan      String?
  userId       String?
  pelangganId  String?
  user         User?             @relation(fields: [userId], references: [id])
  pelanggan    Pelanggan?        @relation(fields: [pelangganId], references: [id])
  createdAt    DateTime          @default(now())
  details      DetailTransaksi[]
  payments     Payment[]
}

model DetailTransaksi {
  id          String      @id @default(cuid())
  transaksiId String
  transaksi   Transaction @relation(fields: [transaksiId], references: [id])
  produkId    String
  produk      Produk      @relation(fields: [produkId], references: [id])
  qty         Int
  harga       Int
  diskon      Int         @default(0)
  subtotal    Int
  catatan     String?

  @@map("TransactionDetail")
}

model Payment {
  id          String      @id @default(cuid())
  transaksiId String
  transaksi   Transaction @relation(fields: [transaksiId], references: [id])
  metode      String
  jumlah      Int
  createdAt   DateTime    @default(now())
}

model StokMovement {
  id        String   @id @default(cuid())
  produkId  String
  produk    Produk   @relation(fields: [produkId], references: [id])
  tipe      String
  jumlah    Int
  referensi String?
  catatan   String?
  createdAt DateTime @default(now())
}