generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String            @id @default(cuid())
  barcode     String            @unique
  nama        String
  harga       Int
  stok        Int               @default(0)
  gambar      String?
  kategori    String?
  deskripsi   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  details     TransactionDetail[]
}

model Transaction {
  id           String              @id @default(cuid())
  nomor        String              @unique
  subtotal     Int
  diskon       Int                 @default(0)
  pajak        Int
  grandTotal   Int
  bayar        Int
  kembalian    Int
  metodeBayar  String
  userId       String
  createdAt    DateTime            @default(now())
  details      TransactionDetail[]
}

model TransactionDetail {
  id            String      @id @default(cuid())
  transaksiId   String
  transaksi     Transaction @relation(fields: [transaksiId], references: [id])
  produkId      String
  produk        Product     @relation(fields: [produkId], references: [id])
  qty           Int
  harga         Int
  subtotal      Int
}